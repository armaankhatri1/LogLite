{
  "name": "loglite",
  "version": "1.0.0",
  "description": "LogLite is a lightweight, JavaScript-based log analysis and visualization tool designed to provide basic operational and security visibility for small applications.",
  "private": true,
  "scripts": {
    "dev": "concurrently \"node server.js\" \"next dev\"",
    "dev:api": "node server.js",
    "dev:ui": "next dev",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "test": "node test.js",
    "lint": "eslint . --ignore-pattern .next",
    "lint:fix": "eslint . --fix --ignore-pattern .next",
    "generate:console": "node sampleApp.js console",
    "generate:winston": "node sampleApp.js winston"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/armaankhatri1/LogLite.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/armaankhatri1/LogLite/issues"
  },
  "homepage": "https://github.com/armaankhatri1/LogLite#readme",
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "express": "^5.2.1",
    "lucide-react": "^0.564.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "2.15.0",
    "tailwind-merge": "^3.3.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  }
